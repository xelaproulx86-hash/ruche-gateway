# 🐝 ruche-gateway — variables d'environnement
# Copie ce fichier en .env (ou configure Settings > Variables and secrets
# sur le Space / l'endpoint RunPod). Aucune clé dans le code : env only.

# ── Gateway ──────────────────────────────────────────────────────────
# Jeton d'accès requis par ruche_task / ruche_chat / GET /claude / POST /hook
GATEWAY_TOKEN=change-me
# Longueur max d'une tâche ou d'un prompt (caractères)
MAX_TASK_CHARS=8000
# Niveau de log (DEBUG, INFO, WARNING…)
LOG_LEVEL=INFO

# ── T2 : GPU RunPod (optionnel — le gateway marche en gratuit seul) ──
# https://api.runpod.ai/v2/<endpoint-id>/openai/v1
RUNPOD_BASE_URL=
RUNPOD_API_KEY=
MODEL_NAME=qwen/qwen2.5-14b-instruct-awq

# ── T1 : chaîne gratuite (chaque clé est optionnelle; sans clé = sauté) ──
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=

# ── Greffe hivebase (dormante sans GITHUB_TOKEN) ─────────────────────
GITHUB_TOKEN=
HIVE_REPO=xelaproulx86-hash/ruche
HIVE_MODULE=hivebase
# 1 = scanner tout le package au lieu du dict TOOLS explicite
HIVE_AUTOSCAN=0

# ── Vault : mémoire persistante git (optionnel) ──────────────────────
# Sans VAULT_REPO : mémoire éphémère dans /tmp (perdue au redémarrage).
# Avec (+ GITHUB_TOKEN) : la mémoire vit dans un clone de ce repo et
# chaque remember est commité + poussé.
VAULT_REPO=
# ex: VAULT_REPO=xelaproulx86-hash/ruche-memory-vault

# ── Intégrations (optionnel) ─────────────────────────────────────────
N8N_WEBHOOK=
